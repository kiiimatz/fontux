{
  "name": "@kiiimatz/fontux",
  "version": "0.2.3",
  "description": "Lightweight font management library for SvelteKit and beyond",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    },
    "./hooks": {
      "import": {
        "types": "./dist/hooks.server.d.ts",
        "default": "./dist/hooks.server.js"
      },
      "require": {
        "types": "./dist/hooks.server.d.cts",
        "default": "./dist/hooks.server.cjs"
      }
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "svelte",
    "sveltekit",
    "font",
    "typography",
    "css",
    "ssr",
    "ssg"
  ],
  "author": "kiiimatz",
  "license": "MIT",
  "devDependencies": {
    "@sveltejs/package": "^2.5.7",
    "tsup": "^8.3.5",
    "typescript": "^5.7.3"
  }
}
